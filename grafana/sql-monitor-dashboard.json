  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "sql.execution.time: 以 Prometheus histogram 为基础绘制 P50/P95/P99（需 percentileHistogram=true）。",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum(rate(sql_execution_time_seconds_bucket{sqlType=~\"$sqlType\",dbType=~\"$dbType\",tables=~\"$tables\"}[5m])) by (le))",
          "legendFormat": "p50",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(sql_execution_time_seconds_bucket{sqlType=~\"$sqlType\",dbType=~\"$dbType\",tables=~\"$tables\"}[5m])) by (le))",
          "legendFormat": "p95",
          "range": true,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum(rate(sql_execution_time_seconds_bucket{sqlType=~\"$sqlType\",dbType=~\"$dbType\",tables=~\"$tables\"}[5m])) by (le))",
          "legendFormat": "p99",
          "range": true,
          "refId": "C"
        }
      ],
      "title": "SQL Latency (P50/P95/P99)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "sql.slow.count: 慢 SQL 计数器（Counter）。",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(sql_slow_count_total{sqlType=~\"$sqlType\",dbType=~\"$dbType\"}[5m]))",
          "legendFormat": "slow_sql_rate",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Slow SQL Rate (5m)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "sql.execution.time: QPS（基于 _count）。",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(sql_execution_time_seconds_count{sqlType=~\"$sqlType\",dbType=~\"$dbType\",tables=~\"$tables\"}[5m]))",
          "legendFormat": "qps",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "SQL QPS (5m)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "慢 SQL 占比 = slow / total。",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "id": 4,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * (sum(rate(sql_slow_count_total{sqlType=~\"$sqlType\",dbType=~\"$dbType\"}[5m])) / sum(rate(sql_execution_time_seconds_count{sqlType=~\"$sqlType\",dbType=~\"$dbType\",tables=~\"$tables\"}[5m])))",
          "legendFormat": "slow_ratio",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Slow SQL Ratio (5m)",
      "type": "stat"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
